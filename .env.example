# ─────────────────────────────────────────────────────────────
# All in one converter — Root environment template
# Copy to `.env` and fill in. Frontend/backend also have their own
# scoped .env.example files. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# --- Supabase (shared) ---
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Public anon key (safe for browser)
SUPABASE_ANON_KEY=
# Service-role key (BACKEND ONLY — full DB access, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=
# Supabase Postgres connection string (for migrations / direct access)
DATABASE_URL=

# --- Frontend ---
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Backend ---
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000
# Max upload size in megabytes (per file)
MAX_UPLOAD_MB=100
# Minutes before processed/uploaded files are auto-deleted
FILE_RETENTION_MINUTES=60
# Rate limit: requests per minute per client
RATE_LIMIT_PER_MINUTE=60
# Secret used to sign internal/download tokens
APP_SECRET_KEY=change-me-in-production

# --- External binaries (override if not on PATH) ---
TESSERACT_CMD=tesseract
LIBREOFFICE_CMD=soffice
FFMPEG_CMD=ffmpeg
