# Backend environment — copy to `.env`

API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated list of allowed CORS origins (the frontend URLs)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Upload constraints
MAX_UPLOAD_MB=100

# Auto-delete processed files after this many minutes
FILE_RETENTION_MINUTES=60

# Per-IP rate limit (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# Secret for signing internal download tokens
APP_SECRET_KEY=change-me-in-production

# Where processed files are stored on disk
STORAGE_DIR=./storage

# External binaries (override if not on PATH)
TESSERACT_CMD=tesseract
LIBREOFFICE_CMD=soffice
FFMPEG_CMD=ffmpeg

# Optional: Supabase (service-role key, backend only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LLM for Image Caption + better Document Translation (Google AI Studio)
GEMINI_API_KEY=your-key-from-aistudio-here
