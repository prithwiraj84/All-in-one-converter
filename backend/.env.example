# Backend environment — copy to `.env`

API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated list of allowed CORS origins (the frontend URLs)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Upload constraints
MAX_UPLOAD_MB=100

# Auto-delete processed files after this many minutes
FILE_RETENTION_MINUTES=60

# Per-IP rate limit (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# Secret for signing internal download tokens
APP_SECRET_KEY=change-me-in-production

# Where processed files are stored on disk
STORAGE_DIR=./storage

# External binaries (override if not on PATH)
TESSERACT_CMD=tesseract
LIBREOFFICE_CMD=soffice
FFMPEG_CMD=ffmpeg
UNAR_CMD=unar

# Optional: Supabase (service-role key, backend only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI tools ───────────────────────────────────────────────────────
# LLM for Image Caption + better Document Translation. Gemini preferred
# (Google AI Studio); Anthropic is an optional fallback. Leave blank to disable
# captioning (translation then falls back to the free Google engine).
GEMINI_API_KEY=your-key-from-aistudio-here
GEMINI_MODEL=gemini-3.1-flash-lite
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Speech-to-text (faster-whisper). Model size: tiny | base | small.
WHISPER_MODEL=base
WHISPER_CPU_THREADS=2

# Colorization model (~123 MB) downloaded on first use — override if it 404s.
# COLORIZE_MODEL_URL=https://www.dropbox.com/s/dx0qvhhp5hbcx7z/colorization_release_v2.caffemodel?dl=1

# ── Concurrency / backpressure ─────────────────────────────────────
# Caps simultaneous jobs so a small instance can't be OOM-crashed. Heavy tools
# (documents, video, AI) use the tighter cap; over-limit requests get a 503.
MAX_CONCURRENT_JOBS=6
MAX_CONCURRENT_HEAVY=2
JOB_QUEUE_TIMEOUT_SECONDS=20

# ── Payments (Razorpay) ────────────────────────────────────────────
# From the Razorpay Dashboard → Settings → API Keys (use Test keys first).
# Leave blank to disable the Upgrade-to-Pro flow.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Set the same value in Razorpay Dashboard → Webhooks (events: payment.captured, order.paid)
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
# Amounts in the smallest unit (paise for INR). Defaults: Pro ₹749, Business ₹2,499.
RAZORPAY_CURRENCY=INR
RAZORPAY_PRO_AMOUNT=74900
RAZORPAY_BUSINESS_AMOUNT=249900
# Days of Pro granted per successful payment (one-time, then auto-reverts to Free).
PRO_PERIOD_DAYS=30
