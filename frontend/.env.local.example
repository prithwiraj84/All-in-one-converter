# Frontend environment — copy to `.env.local`
# Public values are exposed to the browser (NEXT_PUBLIC_*). Do not put secrets here.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Base URL of the FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Canonical site URL (used for SEO metadata / OpenGraph / sitemaps)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google AdSense (ads shown to Free/anonymous users only, after cookie consent).
# Leave blank to disable ads entirely. The publisher id (ca-pub-…) also generates
# /ads.txt. NEXT_PUBLIC_ADSENSE_SLOT is a default ad-unit id for <AdUnit/>.
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT=
# Use Google's Funding Choices CMP for consent (recommended; geo-aware, required
# for EEA/UK). Set to "false" to use the simple built-in cookie banner instead.
NEXT_PUBLIC_USE_GOOGLE_CMP=true
